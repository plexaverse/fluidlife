# ─── Database (Supabase pooled connection — port 6543, transaction mode) ────
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ─── Admin auth ─────────────────────────────────────────────────────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=
JWT_SECRET=
# `openssl rand -base64 32` for each:
USER_ACCESS_SECRET=
USER_REFRESH_SECRET=

# ─── OTP provider (2Factor.in) ──────────────────────────────────────────────
TWO_FACTOR_BASE_URL=https://2factor.in/API/V1/
TWO_FACTOR_AUTH_KEY=

# ─── Razorpay ───────────────────────────────────────────────────────────────
RAZORPAY_WEBHOOK_SECRET=
# Required for refund + reconciliation endpoints:
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Supabase Storage ───────────────────────────────────────────────────────
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=images

# ─── Shiprocket ─────────────────────────────────────────────────────────────
SHIPROCKET_WEBHOOK_TOKEN=
# Required for the /api/admin/orders/[orderId]/ship endpoint:
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=
# DLT-registered SMS template names (one per notification type):
# SMS_TEMPLATE_ORDER_CONFIRMED=
# SMS_TEMPLATE_ORDER_SHIPPED=
# SMS_TEMPLATE_ORDER_DELIVERED=
# SMS_TEMPLATE_ORDER_REFUNDED=

# ─── CORS ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://www.example.com,https://admin.example.com

# ─── Supabase Storage (image uploads) ───────────────────────────────────────
# Project URL: https://<ref>.supabase.co  (Settings → API → Project URL)
SUPABASE_URL=https://<ref>.supabase.co
# Settings → API → service_role key (keep secret — server-side only)
SUPABASE_SERVICE_ROLE_KEY=
# Bucket name to upload images into (create it in Storage → New bucket, set Public)
SUPABASE_STORAGE_BUCKET=images

# ─── Upstash Redis (rate limiting) ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Postgres pool tuning ───────────────────────────────────────────────────
# PG_POOL_MAX=3
# PG_STATEMENT_TIMEOUT_MS=10000

# ─── Analytics (optional) ───────────────────────────────────────────────────
# POST URL that receives JSON events: order.created, order.paid, order.shipped,
# order.delivered, order.refunded, order.cancelled.
# Works with Segment webhooks, GA4 Measurement Protocol, PostHog, Mixpanel, etc.
# ANALYTICS_WEBHOOK_URL=

# ─── Logging / observability ────────────────────────────────────────────────
# LOG_LEVEL=info
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Order configuration ────────────────────────────────────────────────────
# Minutes before an unpaid PREPAID order auto-cancels (releases stock + coupon).
# PAYMENT_EXPIRY_MINUTES=15
# Order subtotal at/above which delivery is free. 0 = always charge.
# FREE_SHIPPING_THRESHOLD=0

# ─── Notifications (Resend) ─────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@example.com
STORE_URL=https://www.example.com

# ─── Seller info (for GST-compliant invoices) ───────────────────────────────
SELLER_NAME=
SELLER_GSTIN=
SELLER_PAN=
SELLER_ADDRESS=
SELLER_STATE=
SELLER_PINCODE=
SELLER_EMAIL=
SELLER_PHONE=
